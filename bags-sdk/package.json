{
  "name": "bags-sdk",
  "version": "0.1.0",
  "description": "Unified SDK for Bags.fm — wraps Bags API, Helius, DFlow, Privy, and Birdeye into one interface",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prebuild": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run test",
    "example:launch": "ts-node examples/launch-token.ts",
    "example:trade": "ts-node examples/trade.ts",
    "example:stream": "ts-node examples/stream-events.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bags-fm/bags-sdk"
  },
  "keywords": [
    "bags",
    "bags.fm",
    "solana",
    "sdk",
    "helius",
    "dflow"
  ],
  "dependencies": {
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.91.8",
    "bs58": "^5.0.0",
    "cross-fetch": "^4.0.0",
    "eventemitter3": "^5.0.1",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "@privy-io/server-auth": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@privy-io/server-auth": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bs58": "^4.0.4",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.1"
  }
}
